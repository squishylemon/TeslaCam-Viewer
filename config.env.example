# Created/updated by setup.ps1 (Windows) or setup.sh (Linux). LAN_IP is auto-detected.
LAN_IP=
SITE_HOSTNAME=teslacam.local
WEB_PORT=4321
# false = http://teslacam.local:4321 like Home Assistant. true = HTTPS (required for passkeys).
USE_HTTPS=false
SESSION_SECRET=change-me-use-a-long-random-string
