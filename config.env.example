# Created by setup.ps1 / setup.sh (LAN_IP auto-detected). Change YOUR_GITHUB_USER after you publish images.
LAN_IP=
SITE_HOSTNAME=teslacam.local
WEB_PORT=4321
USE_HTTPS=false
# Linux mDNS: auto (host Avahi if available), host, container, or off
MDNS_MODE=auto
SESSION_SECRET=change-me-use-a-long-random-string

# Pre-built images (default). Override if you publish under your own GHCR org.
TESLACAM_WEB_IMAGE=ghcr.io/YOUR_GITHUB_USER/teslacam-web:latest
TESLACAM_SFTP_IMAGE=ghcr.io/YOUR_GITHUB_USER/teslacam-sftp:latest
TESLACAM_SFTP_INIT_IMAGE=ghcr.io/YOUR_GITHUB_USER/teslacam-sftp-init:latest
TESLACAM_HOST_MDNS_IMAGE=ghcr.io/YOUR_GITHUB_USER/teslacam-host-mdns:latest
TESLACAM_MDNS_IMAGE=ghcr.io/YOUR_GITHUB_USER/teslacam-mdns:latest
