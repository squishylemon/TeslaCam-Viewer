---
import type { SessionUser } from '../lib/auth/session';
import type { SftpConnectionInfo } from '../lib/sftp-info';
import type { SiteAccessInfo } from '../lib/site-hostname';

interface Props {
  user: SessionUser;
  logoUrl: string | null;
  sftp: SftpConnectionInfo;
  siteAccess: SiteAccessInfo;
  libraryValid: boolean;
  librarySavedCount?: number;
  librarySentryCount?: number;
  libraryVehicleCount?: number;
  builtinSftpEnabled?: boolean;
  initialOpen?: boolean;
}

const {
  user,
  logoUrl,
  sftp,
  siteAccess,
  libraryValid,
  librarySavedCount = 0,
  librarySentryCount = 0,
  libraryVehicleCount = 0,
  builtinSftpEnabled = true,
  initialOpen = false,
} = Astro.props;
const showAuthenticator = !user.hasPasskey;
const showPasskeyUpgrade = !user.hasPasskey;
const isAdmin = user.isAdmin;
---

<div
  id="settings-overlay"
  class="settings-overlay"
  hidden={!initialOpen}
  aria-hidden={initialOpen ? 'false' : 'true'}
>
  <button
    type="button"
    class="settings-overlay-backdrop"
    id="settings-backdrop"
    aria-label="Close settings"
  />
  <div
    class="settings-overlay-panel"
    role="dialog"
    aria-modal="true"
    aria-labelledby="settings-overlay-title"
  >
    <header class="settings-overlay-header">
      <button type="button" class="settings-close-btn" id="settings-close" aria-label="Close settings">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M18.3 5.71a1 1 0 0 0-1.41 0L12 10.59 7.11 5.7A1 1 0 0 0 5.7 7.11L10.59 12l-4.9 4.89a1 1 0 1 0 1.41 1.42L12 13.41l4.89 4.9a1 1 0 0 0 1.42-1.42L13.41 12l4.9-4.89a1 1 0 0 0-.01-1.4z" />
        </svg>
        <span>Close</span>
      </button>
      <h2 id="settings-overlay-title" class="settings-overlay-title">Settings</h2>
      <span class="settings-header-spacer" aria-hidden="true" />
    </header>

    <main class="settings-page">
      <section class="settings-section">
        <div class="settings-card account-card">
          <div class="account-card-top">
            <span class="account-avatar" aria-hidden="true">
              {user.username.slice(0, 1).toUpperCase()}
            </span>
            <div class="account-card-info">
              <p class="settings-label account-card-label">Account</p>
              <p class="account-username">{user.username}</p>
              {
                isAdmin && <span class="user-pill user-pill--admin">Administrator</span>
              }
            </div>
          </div>
          <button type="button" class="step-btn account-signout-btn" id="btn-logout">
            Sign out
          </button>
        </div>
      </section>

      {
        isAdmin && (
          <section class="settings-section">
            <h2>Security</h2>
            <p class="settings-note">Passkeys and authenticator apps for your account.</p>
            <div class="auth-cards">
          <article
            class:list={[
              'auth-card',
              user.hasPasskey ? 'auth-card--on' : 'auth-card--off',
            ]}
          >
            <div class="auth-card-icon auth-card-icon--passkey" aria-hidden="true">
              <svg viewBox="0 0 24 24">
                <path
                  d="M12 2a5 5 0 0 1 5 5v2h1a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2V11a2 2 0 0 1 2-2h1V7a5 5 0 0 1 5-5zm0 2a3 3 0 0 0-3 3v2h6V7a3 3 0 0 0-3-3z"
                />
              </svg>
            </div>
            <div class="auth-card-body">
              <h3>Passkey</h3>
              {
                user.hasPasskey ? (
                  <>
                    <span class="auth-status auth-status--on">Enabled</span>
                    <p>Face ID, Touch ID, Windows Hello, or a security key.</p>
                  </>
                ) : (
                  <>
                    <span class="auth-status auth-status--rec">Recommended</span>
                    <p>Faster sign-in with biometrics or a security key.</p>
                    {showPasskeyUpgrade && (
                      <>
                        <button type="button" class="step-btn" id="btn-add-passkey">
                          Add passkey
                        </button>
                        <p id="passkey-upgrade-status" class="auth-card-hint" />
                      </>
                    )}
                  </>
                )
              }
            </div>
          </article>

          {
            showAuthenticator && (
              <article
                class:list={[
                  'auth-card',
                  user.hasTotp ? 'auth-card--on' : 'auth-card--off',
                ]}
              >
                <div class="auth-card-icon auth-card-icon--totp" aria-hidden="true">
                  <svg viewBox="0 0 24 24">
                    <path
                      d="M4 6h16v2H4V6zm0 5h16v2H4v-2zm0 5h10v2H4v-2zM17 16h1l2 2v2h-2v-2l-2-2z"
                    />
                  </svg>
                </div>
                <div class="auth-card-body">
                  <h3>Authenticator app</h3>
                  {
                    user.hasTotp ? (
                      <>
                        <span class="auth-status auth-status--on">Enabled</span>
                        <p>Time-based codes from your authenticator app.</p>
                      </>
                    ) : (
                      <>
                        <span class="auth-status auth-status--off">Not set</span>
                        <p>
                          Set up during initial security setup if you do not use a
                          passkey.
                        </p>
                      </>
                    )
                  }
                </div>
              </article>
            )
          }
            </div>
          </section>
        )
      }

      {
        isAdmin && (
          <section
            class="settings-section"
            id="users-admin-section"
            data-self-id={user.id}
            data-root-admin-id="1"
          >
            <h2>Users</h2>
            <p class="settings-note">
              Create accounts and manage sign-in methods.
            </p>

            <div class="settings-card users-admin-card">
              <div class="users-tabs" role="tablist" aria-label="User management">
                <button
                  type="button"
                  class="users-tab active"
                  id="users-tab-create"
                  role="tab"
                  aria-selected="true"
                  aria-controls="users-panel-create"
                  data-users-tab="create"
                >
                  New user
                </button>
                <button
                  type="button"
                  class="users-tab"
                  id="users-tab-list"
                  role="tab"
                  aria-selected="false"
                  aria-controls="users-panel-list"
                  data-users-tab="list"
                >
                  Existing users
                  <span id="users-count" class="users-tab-count" hidden />
                </button>
              </div>

              <div
                id="users-panel-create"
                class="users-tab-panel"
                role="tabpanel"
                aria-labelledby="users-tab-create"
              >
                <form id="create-user-form" class="admin-form">
                  <label class="admin-field">
                    <span>Username</span>
                    <input
                      type="text"
                      id="create-username"
                      name="username"
                      autocomplete="off"
                      required
                      minlength={2}
                      maxlength={32}
                      pattern="[a-zA-Z0-9][a-zA-Z0-9._-]*"
                    />
                  </label>
                  <label class="admin-field">
                    <span>Password</span>
                    <div class="password-row">
                      <input
                        type="text"
                        id="create-password"
                        name="password"
                        autocomplete="new-password"
                        required
                        minlength={8}
                      />
                      <button type="button" class="btn-secondary" id="btn-gen-create-password">
                        Regenerate
                      </button>
                    </div>
                  </label>
                  <label class="admin-check">
                    <input type="checkbox" id="create-force-mfa" name="forceMfa" checked />
                    <span>Require 2FA on first login (passkey or authenticator)</span>
                  </label>
                  <label class="admin-check">
                    <input type="checkbox" id="create-is-admin" name="isAdmin" />
                    <span>Administrator (full settings access)</span>
                  </label>
                  <p id="create-user-status" class="admin-status" />
                  <button type="submit" class="step-btn">Create user</button>
                </form>
              </div>

              <div
                id="users-panel-list"
                class="users-tab-panel"
                role="tabpanel"
                aria-labelledby="users-tab-list"
                hidden
              >
                <p id="users-load-status" class="users-load-status">Loading users…</p>
                <div id="users-list" class="users-list" hidden />
              </div>
            </div>
          </section>
        )
      }

      <section class="settings-section">
        <h2>{isAdmin ? 'Appearance' : 'Theme'}</h2>
        {
          isAdmin && (
            <p class="settings-note">Theme and branding for the viewer.</p>
          )
        }

        <div class="settings-card theme-card">
          <p class="settings-label">Theme</p>
          <div
            id="theme-picker"
            class="theme-picker"
            role="radiogroup"
            aria-label="Theme"
          >
            <button
              type="button"
              class="theme-option"
              data-theme-value="system"
              role="radio"
              aria-checked="true"
            >
              System
            </button>
            <button
              type="button"
              class="theme-option"
              data-theme-value="dark"
              role="radio"
              aria-checked="false"
            >
              Dark
            </button>
            <button
              type="button"
              class="theme-option"
              data-theme-value="light"
              role="radio"
              aria-checked="false"
            >
              Light
            </button>
          </div>
        </div>

        {
          isAdmin && (
            <div class="settings-card logo-card">
              <p class="settings-label">Custom logo</p>
              <p class="logo-note">
                Shown in the top bar and sign-in page. PNG, JPEG, WebP, or SVG.
              </p>
              <div class="logo-preview-wrap">
                {
                  logoUrl ? (
                    <img
                      id="logo-preview"
                      class="logo-preview"
                      src={logoUrl}
                      alt="Current custom logo"
                    />
                  ) : (
                    <div class="logo-preview logo-preview--empty" id="logo-preview">
                      Default branding
                    </div>
                  )
                }
              </div>
              <input
                type="file"
                id="logo-file"
                name="logo"
                accept="image/png,image/jpeg,image/webp,image/svg+xml"
                hidden
              />
              <div
                id="logo-dropzone"
                class="logo-dropzone"
                tabindex="0"
                role="group"
                aria-label="Logo upload"
              >
                <p class="logo-dropzone-title">Drag &amp; drop to replace logo</p>
                <p class="logo-dropzone-hint">Uploads automatically when you pick a file</p>
                <button type="button" class="logo-select-btn" id="logo-select">
                  Select image
                </button>
              </div>
              <p id="logo-status" class="logo-status" />
              <button
                type="button"
                class="btn-text-danger"
                id="btn-remove-logo"
                hidden={!logoUrl}
              >
                Remove custom logo
              </button>
            </div>
          )
        }
      </section>

      {
        isAdmin && (
          <section class="settings-section" id="libraries-admin-section">
            <h2>Library locations</h2>
            <p class="settings-note">
              Point the viewer at folders on this server, a NAS, or a DAS (SMB). Only administrators
              can change locations.
            </p>
            <div class="settings-card libraries-card">
              <label class="admin-check libraries-toggle">
                <input
                  type="checkbox"
                  id="builtin-sftp-enabled"
                  checked={builtinSftpEnabled}
                />
                <span>Enable built-in SFTP upload location</span>
              </label>
              <p class="field-hint">
                When off, the SFTP upload section is hidden and clips come only from external
                locations below.
              </p>
              <div class="libraries-toolbar">
                <button type="button" class="step-btn" id="btn-new-location">
                  New location
                </button>
              </div>
              <ul id="locations-list" class="locations-list" aria-live="polite" />
              <p id="locations-status" class="admin-status" aria-live="polite" />
            </div>
          </section>
        )
      }

      {
        isAdmin && builtinSftpEnabled && (
          <section class="settings-section" id="upload-section">
            <h2>Upload clips (SFTP)</h2>
            <p class="settings-note">
              Copy TeslaCam footage from your car to this server over SFTP. You connect
              straight into the upload area (no folder path needed). Use per-vehicle folders
              like <code>MX_Name</code>, <code>MY_Name</code>, <code>MS_Name</code>, or{' '}
              <code>M3_Name</code> (each with <code>SavedClips</code> and{' '}
              <code>SentryClips</code> inside).
            </p>
            <div class="settings-card sftp-card">
              <p
                class:list={[
                  'library-status',
                  libraryValid ? 'library-status--ok' : 'library-status--warn',
                ]}
              >
                {
                  libraryValid
                    ? `${libraryVehicleCount} vehicle${libraryVehicleCount === 1 ? '' : 's'} · ${librarySavedCount} saved · ${librarySentryCount} sentry events on server`
                    : 'No clips on the server yet — connect with SFTP below and upload your TeslaCam folder.'
                }
              </p>
              <dl class="sftp-details">
                <div class="sftp-row">
                  <dt>Host</dt>
                  <dd>
                    <code class="sftp-value" data-copy={sftp.host}>{sftp.host}</code>
                    <button type="button" class="sftp-copy" data-copy-target={sftp.host} aria-label="Copy host">
                      Copy
                    </button>
                  </dd>
                </div>
                <div class="sftp-row">
                  <dt>Port</dt>
                  <dd>
                    <code class="sftp-value" data-copy={String(sftp.port)}>{sftp.port}</code>
                    <button
                      type="button"
                      class="sftp-copy"
                      data-copy-target={String(sftp.port)}
                      aria-label="Copy port"
                    >
                      Copy
                    </button>
                  </dd>
                </div>
                <div class="sftp-row">
                  <dt>Username</dt>
                  <dd>
                    <code class="sftp-value" data-copy={sftp.username}>{sftp.username}</code>
                    <button
                      type="button"
                      class="sftp-copy"
                      data-copy-target={sftp.username}
                      aria-label="Copy username"
                    >
                      Copy
                    </button>
                  </dd>
                </div>
                <div class="sftp-row">
                  <dt>Password</dt>
                  <dd>
                    <code class="sftp-value sftp-secret" data-copy={sftp.password}>
                      {sftp.password}
                    </code>
                    <button
                      type="button"
                      class="sftp-copy"
                      data-copy-target={sftp.password}
                      aria-label="Copy password"
                    >
                      Copy
                    </button>
                  </dd>
                </div>
              </dl>
              <div class="sftp-actions">
                <button
                  type="button"
                  class="step-btn sftp-connect-btn"
                  id="btn-sftp-connect"
                  data-connect-url={sftp.connectUrl}
                  data-winscp-url={sftp.winScpUrl}
                >
                  Connect with SFTP app
                </button>
              </div>
              <p class="field-hint">
                <strong>Like Home Assistant:</strong>{' '}
                <a href={siteAccess.siteUrl}>{siteAccess.siteUrl}</a> (mDNS from setup script). Or by IP:{' '}
                <a href={siteAccess.directUrl}>{siteAccess.directUrl}</a>. Allow port{' '}
                <strong>{sftp.port}</strong> through your firewall.
              </p>
              <p class="field-hint">
                Passkeys need <code>USE_HTTPS=true</code> in config.env, then recreate the web container.
              </p>
              <div class="hosts-setup">
                <p class="hosts-setup-title">Hosts file fallback (if .local does not resolve)</p>
                <p class="field-hint">
                  Add on <code>{siteAccess.hostsFilePathWindows}</code> (Administrator):
                </p>
                <code class="hosts-setup-line" data-copy={siteAccess.hostsFileLine}>
                  {siteAccess.hostsFileLine}
                </code>
                <button
                  type="button"
                  class="sftp-copy hosts-setup-copy"
                  data-copy-target={siteAccess.hostsFileLine}
                >
                  Copy hosts line
                </button>
              </div>
              <p id="sftp-copy-status" class="admin-status" aria-live="polite" />
            </div>
          </section>
        )
      }
    </main>
  </div>

  <div
    id="location-modal"
    class="location-modal"
    hidden
    aria-hidden="true"
  >
    <div class="location-modal-backdrop" id="location-modal-backdrop" />
    <div
      class="location-modal-panel"
      role="dialog"
      aria-modal="true"
      aria-labelledby="location-modal-title"
    >
      <h3 id="location-modal-title" class="location-modal-title">New location</h3>
      <form id="location-form" class="location-form">
        <input type="hidden" id="location-edit-id" value="" />
        <label class="admin-field">
          <span>Name</span>
          <input type="text" id="location-name" required placeholder="Home NAS" />
        </label>
        <label class="admin-field">
          <span>Folder path</span>
          <input
            type="text"
            id="location-path"
            required
            placeholder="192.168.50.23/TeslaCam or /mnt/nas/TeslaCam"
          />
          <p class="field-hint">
            SMB examples: <code>192.168.50.23/TeslaCam</code> or <code>//nas/share/TeslaCam</code>.
            Local paths must exist inside the container (bind-mount from the host).
          </p>
        </label>
        <label class="admin-check">
          <input type="checkbox" id="location-requires-credentials" />
          <span>Requires credentials</span>
        </label>
        <div id="location-credentials" class="location-credentials" hidden>
          <label class="admin-field">
            <span>Username</span>
            <input type="text" id="location-username" autocomplete="off" />
          </label>
          <label class="admin-field">
            <span>Password</span>
            <input type="password" id="location-password" autocomplete="new-password" />
          </label>
        </div>
        <label class="admin-check">
          <input type="checkbox" id="location-enabled" checked />
          <span>Enabled</span>
        </label>
        <div class="location-modal-actions">
          <button type="submit" class="step-btn" id="location-save">Save location</button>
          <button type="button" class="btn-ghost" id="location-cancel">Cancel</button>
        </div>
        <p id="location-form-status" class="admin-status" aria-live="polite" />
      </form>
    </div>
  </div>
</div>

<style is:global>
  .settings-overlay {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    justify-content: flex-end;
    pointer-events: none;
  }
  .settings-overlay:not([hidden]) {
    pointer-events: auto;
  }
  .settings-overlay[hidden] {
    display: none !important;
  }
  body.settings-open {
    overflow: hidden;
  }
  .settings-overlay-backdrop {
    position: absolute;
    inset: 0;
    border: 0;
    padding: 0;
    margin: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.52);
    backdrop-filter: blur(3px);
    cursor: pointer;
  }
  .settings-overlay-panel {
    position: relative;
    z-index: 2;
    width: min(100%, 440px);
    pointer-events: auto;
    max-width: 100%;
    height: 100%;
    background: var(--bg);
    border-left: 1px solid var(--border);
    box-shadow: -8px 0 32px rgba(0, 0, 0, 0.28);
    display: flex;
    flex-direction: column;
    animation: settings-slide-in 0.22s ease-out;
  }
  @keyframes settings-slide-in {
    from {
      transform: translateX(100%);
    }
    to {
      transform: translateX(0);
    }
  }
  .settings-overlay-header {
    flex-shrink: 0;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.65rem;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border);
    background: var(--bg);
  }
  .settings-header-spacer {
    width: 4.5rem;
  }
  .settings-close-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    border: 1px solid var(--border);
    background: var(--bg-elev);
    color: var(--text-dim);
    border-radius: 10px;
    padding: 0.4rem 0.7rem;
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
  }
  .settings-close-btn svg {
    width: 16px;
    height: 16px;
    fill: currentColor;
  }
  .settings-close-btn:hover {
    color: var(--text);
    border-color: var(--border-strong);
  }
  .settings-overlay-title {
    font-size: 1rem;
    font-weight: 700;
    text-align: center;
    margin: 0;
  }
  .settings-overlay .settings-page {
    flex: 1;
    overflow-y: auto;
    max-width: none;
    margin: 0;
    padding: 1.5rem 1.1rem 2.5rem;
  }
  .account-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .account-card-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .account-avatar {
    width: 42px;
    height: 42px;
    border-radius: 11px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    font-weight: 800;
    color: var(--accent);
    background: rgba(232, 33, 39, 0.12);
    border: 1px solid rgba(232, 33, 39, 0.28);
    flex-shrink: 0;
  }
  .account-card-info {
    min-width: 0;
  }
  .account-card-label {
    margin-bottom: 0.2rem !important;
  }
  .account-username {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text);
    margin: 0 0 0.35rem;
    word-break: break-all;
  }
  .account-signout-btn {
    width: 100%;
    text-align: center;
  }
  .theme-card {
    position: relative;
    z-index: 1;
  }
  .theme-picker {
    position: relative;
    z-index: 2;
  }
  .theme-option {
    position: relative;
    z-index: 1;
    -webkit-tap-highlight-color: transparent;
  }
  .theme-option:hover {
    color: var(--text);
  }
  .library-status {
    font-size: 0.82rem;
    margin: -0.35rem 0 0.75rem;
    padding: 0.45rem 0.55rem;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--bg-elev);
  }
  .library-status--ok {
    color: #4ade80;
    border-color: rgba(34, 197, 94, 0.35);
  }
  .library-status--warn {
    color: var(--accent);
    border-color: rgba(232, 33, 39, 0.35);
  }
  .libraries-toggle {
    margin-bottom: 0.5rem;
  }
  .libraries-toolbar {
    margin: 0.75rem 0;
  }
  .locations-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .location-item {
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 0.65rem 0.75rem;
    background: var(--bg-elev);
  }
  .location-item-head {
    display: flex;
    justify-content: space-between;
    gap: 0.5rem;
    align-items: flex-start;
  }
  .location-item-name {
    font-weight: 700;
    margin: 0 0 0.2rem;
  }
  .location-item-path {
    font-size: 0.78rem;
    color: var(--text-dim);
    word-break: break-all;
    margin: 0;
  }
  .location-item-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 0.5rem;
  }
  .location-modal {
    position: fixed;
    inset: 0;
    z-index: 300;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }
